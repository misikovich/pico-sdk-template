# Pinned toolchain versions and install locations — the single source of truth.
# Every value can be overridden by exporting the variable before running
# install.sh, e.g.:  PICO_SDK_VERSION=develop ./install.sh
#
# Keep the defaults in platforms/windows.ps1 in sync with this file.

PICO_SDK_VERSION="${PICO_SDK_VERSION:-2.1.1}"
PICOTOOL_VERSION="${PICOTOOL_VERSION:-2.1.1}"

# Everything installed by these scripts lives under PICO_ROOT.
PICO_ROOT="${PICO_ROOT:-$HOME/.pico-sdk}"
PICO_SDK_PATH="${PICO_SDK_PATH:-$PICO_ROOT/sdk/$PICO_SDK_VERSION}"
PICO_ENV_FILE="${PICO_ENV_FILE:-$PICO_ROOT/env.sh}"
